# ─── DATABASE ────────────────────────────────────────────────────────────────
# Render provee esta variable automáticamente cuando configuras "fromDatabase"
# en render.yaml. En local: ajusta a tu PostgreSQL o usa SQLite (ver abajo).
DATABASE_URL=postgresql+asyncpg://smartflow:smartflow123@localhost:5432/smartflow_db

# SQLite para desarrollo local (sin PostgreSQL):
# DATABASE_URL=sqlite+aiosqlite:///./smartflow.db

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── SEGURIDAD ───────────────────────────────────────────────────────────────
# CRÍTICO: Configura esto en Render → Environment → SECRET_KEY
# Genera un valor seguro con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Si no se configura, se usa un fallback fijo de desarrollo (NO seguro en producción).
SECRET_KEY=REPLACE-WITH-SECURE-RANDOM-STRING-MIN-32-CHARS

# ─── ENTORNO ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
FRONTEND_URL=https://smartflow-casbo.onrender.com

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
# Opcional — necesario para envío de contraseñas temporales y bienvenida
RESEND_API_KEY=
FROM_EMAIL=noreply@smartflow.app

# ─── WHATSAPP (Ultra) ─────────────────────────────────────────────────────────
# Opcional
ULTRA_API_KEY=
ULTRA_INSTANCE_ID=

# ─── IA / VOZ ─────────────────────────────────────────────────────────────────
# REQUERIDO para que ARIA responda (chat de voz + análisis de reuniones)
# Obtener GRATIS en: https://ai.google.dev → "Get API key"
GEMINI_API_KEY=

# RECOMENDADO para transcripción de voz (Whisper en la nube, 0 RAM en servidor)
# Sin esta clave, el servidor usa faster-whisper local (~350MB RAM)
# Obtener GRATIS en: https://console.groq.com → API Keys (28,800s audio/día gratis)
GROQ_API_KEY=
# Modelo de Groq para transcripción (whisper-large-v3-turbo = más rápido, whisper-large-v3 = mejor calidad)
GROQ_MODEL=whisper-large-v3-turbo

# ElevenLabs TTS — ya configurado, mover aquí si se usa en producción
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=UgBBYS2sOqTuMpoF3BR0

# ─── WHISPER LOCAL (fallback si no hay GROQ_API_KEY) ─────────────────────────
# 'base' = 350MB RAM, rápido | 'medium' = 1.5GB | 'large-v3' = 3GB
# Render standard plan tiene 512MB → usar 'base' o configurar GROQ_API_KEY
WHISPER_MODEL=base
